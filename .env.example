# Public browser-safe Supabase config
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose this to client bundles.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App-level security knobs
ADMIN_EMAIL_DOMAIN=mechconnect.in
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# Deployment
NEXT_PUBLIC_CUSTOMER_APP_URL=http://localhost:3000
NEXT_PUBLIC_MECHANIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_GARAGE_APP_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3003
