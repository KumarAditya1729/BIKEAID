# Public browser-safe Supabase config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only. Never expose this to client bundles.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App-level security knobs
ADMIN_EMAIL_DOMAIN=mechconnect.in
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30
OTP_PEPPER=generate_a_long_random_secret
NEXT_PUBLIC_ENABLE_CLIENT_LOGS=false

# Deployment
NEXT_PUBLIC_CUSTOMER_APP_URL=https://bikeaid-customer.vercel.app
NEXT_PUBLIC_MECHANIC_APP_URL=https://bikeaid-mechanic.vercel.app
NEXT_PUBLIC_GARAGE_APP_URL=https://bikeaid-garage.vercel.app
NEXT_PUBLIC_ADMIN_APP_URL=https://bikeaid-admin.vercel.app
